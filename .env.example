# 로컬 dry-run 또는 수동 실행 시 사용하는 예시 환경변수.
# 실제 값은 GitHub Secrets 에만 저장하고, 로컬 .env 파일은 절대 커밋하지 않는다.

# Notion Integration token (secret_ 으로 시작)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "GRM API Intake" Database ID (Notion URL 의 32자 hex)
NOTION_DATABASE_ID=00000000000000000000000000000000

# OpenFDA 무료 API key (선택 — 없으면 no-key 모드, rate limit 낮음)
OPENFDA_API_KEY=

# Brave Search API key (ENABLE_SEARCH=true일 때 필요)
BRAVE_API_KEY=

# 법제처 ogLmPp OC/API 키 (ENABLE_MOLEG_API=true일 때만 사용)
DATA_GO_KR_KEY=

# data.go.kr 식약처 API key
# - 15059114 의약품 회수·판매중지 (ENABLE_MFDS_RECALL=true)
# - 15058457 의약품 행정처분 (ENABLE_MFDS_ADMIN=true)
DATA_GO_KR_SERVICE_KEY=

# Feature flags
ENABLE_SEARCH=false
ENABLE_MFDS=false
ENABLE_MFDS_RECALL=false
ENABLE_MFDS_ADMIN=false
ENABLE_MFDS_GMP_INSPECTION=false
ENABLE_ICH=false
ENABLE_WHO=false
ENABLE_HC=false
ENABLE_MOLEG_API=false
ENABLE_SCRAPE=false
# WHY-1: 글로벌 소스 결함 본문 excerpt(기본 off — dry-run 검증 후 on, 바이오 1단계 패턴).
#  - ENABLE_WHOPIR_EXCERPT: WHO WHOPIR PDF 에서 영문 결함 구간 추출(ENABLE_WHO=true 전제)
#  - ENABLE_WL_BODY: FDA Warning Letter 편지 본문에서 위반 서술 추출
# 실패는 graceful(키 미기록·항목은 링크/메타 카드로 유지) — 수집 전체 실패 없음.
ENABLE_WHOPIR_EXCERPT=false
ENABLE_WL_BODY=false
# 제품군(Modality) 태그 기록 — Notion Intake DB 에 'Modality' select 속성을 먼저 만든 뒤 true 로.
# (속성 미생성 상태에서 true 로 켜면 insert 가 실패하므로 순서 주의)
ENABLE_MODALITY_TAG=false
# Routine handoff v2 (K3 — scaffold/slots). 기본 off; on 전환은 사람 승인 후.
ENABLE_HANDOFF_V2=false

# ICH 수집 윈도우는 없음(스냅샷 방식). 회수·행정처분 지연공개 backfill 윈도우(일):
MFDS_ENFORCEMENT_WINDOW_DAYS=30
