# 로컬 dry-run 또는 수동 실행 시 사용하는 예시 환경변수.
# 실제 값은 GitHub Secrets 에만 저장하고, 로컬 .env 파일은 절대 커밋하지 않는다.

# Notion Integration token (secret_ 으로 시작)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "GRM API Intake" Database ID (Notion URL 의 32자 hex)
NOTION_DATABASE_ID=00000000000000000000000000000000

# OpenFDA 무료 API key (선택 — 없으면 no-key 모드, rate limit 낮음)
OPENFDA_API_KEY=

# Brave Search API key (ENABLE_SEARCH=true일 때 필요)
BRAVE_API_KEY=

# 법제처 ogLmPp OC/API 키 (ENABLE_MOLEG_API=true일 때만 사용)
DATA_GO_KR_KEY=

# data.go.kr 식약처 API key
# - 15059114 의약품 회수·판매중지 (ENABLE_MFDS_RECALL=true)
# - 15058457 의약품 행정처분 (ENABLE_MFDS_ADMIN=true)
# - 15000115 법제처 국가법령정보 공유서비스 (ENABLE_MFDS_LAW=true)
# - 15097207 의약품 GMP 적합판정서 발급현황 (ENABLE_MFDS_GMP_CERT=true)
# - 15059182 의약품 안전성서한 정보 (ENABLE_MFDS_SAFETY_LETTER=true)
DATA_GO_KR_SERVICE_KEY=

# law.go.kr DRF OC (선택): ENABLE_MFDS_LAW=true 일 때 고시/행정규칙 전문 본문 enrich.
LAW_GO_KR_OC=

# KR egress 프록시 (선택): MFDS/nedrug/law.go.kr 호스트에만 적용된다.
# 예: http://user:pass@kr-proxy.example.com:3128
MFDS_HTTP_PROXY=

# MFDS RSS 보드 선택. 기본 all=현행 동일, residual=API 미커버 지침 보드(data0013/0011/0010)만.
MFDS_RSS_BOARD_MODE=all
# 명시 allowlist가 필요하면 쉼표/공백 구분으로 지정. 예: data0013,data0011,data0010
MFDS_RSS_BOARD_IDS=

# Feature flags
ENABLE_SEARCH=false
ENABLE_MFDS=false
ENABLE_MFDS_LAW=false
ENABLE_MFDS_RECALL=false
ENABLE_MFDS_ADMIN=false
ENABLE_MFDS_GMP_CERT=false
ENABLE_MFDS_SAFETY_LETTER=false
ENABLE_MFDS_GMP_INSPECTION=false
ENABLE_ICH=false
ENABLE_WHO=false
ENABLE_HC=false
# FDA 483 실사 관찰사항 수집기(가장 깊은 결함 원본).
#  현행 OII FOIA Reading Room HTML/DataTables → Record Type=483 필터 → Publish Date 윈도우
#  (MFDS_ENFORCEMENT_WINDOW_DAYS 재사용) → 건별 PDF 결함 excerpt(P6 엔진·graceful).
#  Observation 상세보기는 별도 opt-in(실패 시 요약카드 유지). --sources fda483 단독 실행 가능.
ENABLE_FDA_483=true
ENABLE_FDA_483_OBSERVATIONS=false
ENABLE_MOLEG_API=false
ENABLE_SCRAPE=false
# WHY-1: 글로벌 소스 결함 본문 excerpt(기본 off — dry-run 검증 후 on, 바이오 1단계 패턴).
#  - ENABLE_WHOPIR_EXCERPT: WHO WHOPIR PDF 에서 영문 결함 구간 추출(ENABLE_WHO=true 전제)
#  - ENABLE_WL_BODY: FDA Warning Letter 편지 본문에서 위반 서술 추출
# 실패는 graceful(키 미기록·항목은 링크/메타 카드로 유지) — 수집 전체 실패 없음.
ENABLE_WHOPIR_EXCERPT=false
ENABLE_WL_BODY=false
# 제품군(Modality) 태그 기록 — Notion Intake DB 에 'Modality' select 속성을 먼저 만든 뒤 true 로.
# (속성 미생성 상태에서 true 로 켜면 insert 가 실패하므로 순서 주의)
ENABLE_MODALITY_TAG=false
# Routine handoff v2 (K3 — scaffold/slots). 기본 off; on 전환은 사람 승인 후.
ENABLE_HANDOFF_V2=false
# PL-10b/B1 멱등성 근본해결 — Handoff Ref 상태기계(소비 자격을 날짜 윈도우가 아니라
# handoff ref 로 판정 → 중복 발행·조용한 누락 동시 차단). 기본 off = 현행 동작 100% 동일.
# on 전제: ① Notion Intake DB 에 'Handoff Ref'(Rich text) 속성 수동 생성(부재 시
# preflight 가 그 실행만 v1 폴백 + health warning) ② K3 4주 관찰 종료 + 사람 승인.
ENABLE_HANDOFF_IDEMPOTENCY_V2=false
# E2(URL전수검사): 행정처분 건별 L1(nedrug getItem?dispsApplySeq=)을 collect 시점에
# 실제 GET 해 검증 → 통과분만 검증된 L1, 실패분은 L2 인덱스+⚠️ 로 강등(scaffold 가 존중).
# 기본 off = 수집기 동작·golden 100% 동일. on 전제: K3 4주 관찰 종료 또는 명시 opt-in
# (건별 nedrug GET 추가 → 수집 시간 증가). data.go.kr 키와 무관(nedrug 공개 페이지).
ENABLE_MFDS_URL_VERIFY=false

# ICH 수집 윈도우는 없음(스냅샷 방식). 회수·행정처분 지연공개 backfill 윈도우(일):
MFDS_ENFORCEMENT_WINDOW_DAYS=30
